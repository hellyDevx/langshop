// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model TranslationJob {
  id             String   @id @default(uuid())
  shop           String
  status         String   @default("pending")
  provider       String
  resourceType   String
  sourceLocale   String
  targetLocale   String
  marketId       String?
  totalItems     Int      @default(0)
  completedItems Int      @default(0)
  failedItems    Int      @default(0)
  errorMessage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  entries TranslationJobEntry[]

  @@index([shop, status])
  @@index([shop, createdAt])
}

model TranslationJobEntry {
  id              String   @id @default(uuid())
  jobId           String
  resourceId      String
  key             String
  sourceValue     String
  translatedValue String?
  status          String   @default("pending")
  errorMessage    String?
  createdAt       DateTime @default(now())

  job TranslationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, status])
}

model TranslationProviderConfig {
  id        String   @id @default(uuid())
  shop      String
  provider  String
  apiKey    String
  projectId String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, provider])
}

model ImageTranslation {
  id                 String   @id @default(uuid())
  shop               String
  resourceId         String
  locale             String
  marketId           String?
  originalImageUrl   String
  translatedImageUrl String
  metafieldId        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([shop, resourceId, locale, marketId])
  @@index([shop, resourceId])
}
